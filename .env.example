# Outlook Auto Login - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ─── Proxy ───
# Manual proxy (if not using Webshare API)
PROXY_URL=http://YOUR_PROXY_USER:YOUR_PROXY_PASS@YOUR_PROXY_HOST:PORT

# ─── Recovery Emails ───
# Gmail accounts used as recovery emails for Outlook
# Format: email:app_password (comma separated)
# Generate App Password at: https://myaccount.google.com/apppasswords
RECOVERY_EMAILS=recovery1@gmail.com:xxxx-xxxx-xxxx-xxxx,recovery2@gmail.com:xxxx-xxxx-xxxx-xxxx

# ─── Telegram Bot ───
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Telegram user ID (comma separated for multiple users)
# Get your ID: send /start to @userinfobot
# Leave empty to allow all users (not recommended)
TELEGRAM_ALLOWED_USERS=YOUR_USER_ID

# ─── Webshare Proxy (Optional) ───
# API key from https://www.webshare.io/ Dashboard → API
# Set via /proxy command in Telegram bot, or manually here
# WEBSHARE_API_KEY=your_api_key_here
