# Outlook Auto Login - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Proxy (HTTP or SOCKS5)
# Format: http://user:pass@host:port or socks5://user:pass@host:port
PROXY_URL=http://YOUR_PROXY_USER:YOUR_PROXY_PASS@YOUR_PROXY_HOST:PORT

# Recovery emails with IMAP app passwords
# Format: email:app_password (comma separated for multiple)
# These are Gmail accounts used as recovery emails for Outlook accounts
# Each needs an App Password (not regular password) for IMAP access
# Generate at: https://myaccount.google.com/apppasswords
RECOVERY_EMAILS=recovery1@gmail.com:xxxx-xxxx-xxxx-xxxx,recovery2@gmail.com:xxxx-xxxx-xxxx-xxxx
